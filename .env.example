# Copie para .env e ajuste os valores antes de rodar `docker compose up`

# --- Banco de dados ---
POSTGRES_USER=optcg
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=optcg_collection
POSTGRES_PORT=5432

# --- App (Next.js) ---
APP_PORT=3000
# Gere um valor aleatório forte, ex: `openssl rand -base64 32`
NEXTAUTH_SECRET=troque-este-segredo
# Ajuste para o IP/hostname do seu ZimaOS na rede local, ex: http://192.168.1.50:3000
NEXTAUTH_URL=http://localhost:3000
